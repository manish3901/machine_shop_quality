# Environment Configuration Template
# Copy this to .env and modify with your values

# ====== FLASK CONFIG ======
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=dev-secret-key-change-in-production-1234567890

# ====== DATABASE ======
# For PostgreSQL (Recommended for production):
DATABASE_URL=postgresql://postgres:password@localhost:5432/machine_shop_db

# For SQLite (Quick development):
# DATABASE_URL=sqlite:///machine_shop.db

# ====== APPLICATION CONFIG ======
DEBUG=True
TESTING=False

# ====== FILE UPLOADS ======
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes

# ====== SESSION ======
PERMANENT_SESSION_LIFETIME=604800  # 7 days in seconds
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS

# ====== LOGGING ======
LOG_LEVEL=INFO

# ====== EMAIL (for future notifications) ======
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ====== API KEYS (future integrations) ======
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
